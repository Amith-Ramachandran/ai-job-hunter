# Vite exposes envs prefixed with VITE_ to the client. NEVER put secrets here.

# Where the React app talks to the Nest API. In dev, vite proxies /api → :3000
# so this stays as `/api`. In production, set to the API origin.
VITE_API_BASE_URL=/api

# Google OAuth client ID (public — fine to expose).
# Get from https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
