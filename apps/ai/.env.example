# Copy to .env for local development.

# ─── Server ───────────────────────────────────────────────
LOG_LEVEL=info
PORT=8000
# Origin allowed to call this service. The Nest API by default.
ALLOWED_ORIGIN=http://localhost:3000

# ─── OpenAI ───────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# 1536 dim, ~$0.02/M tokens. Switch to text-embedding-3-large (3072 dim)
# only if eval scores demand it.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Qdrant ───────────────────────────────────────────────
# When the AI service runs natively on your Mac, point at the host port.
# When it runs in docker compose, point at the service name (qdrant:6333).
QDRANT_URL=http://localhost:6333
# Collection names — single tenant for now.
QDRANT_CV_COLLECTION=cv_chunks
QDRANT_JOB_COLLECTION=job_chunks
