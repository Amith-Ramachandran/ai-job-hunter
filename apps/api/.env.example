# Copy to .env for local development.

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# Allowed origin for the React frontend (CORS).
WEB_ORIGIN=http://localhost:5173

# ─── Postgres (matches infra/docker-compose.yml) ─────────
DATABASE_URL=postgresql://ajh:ajh_dev_password@localhost:5433/ai_job_hunter?schema=public

# ─── Redis (BullMQ) ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=ajh_redis_dev

# ─── Google OAuth ────────────────────────────────────────
# Get this from https://console.cloud.google.com/apis/credentials
# We only need the client ID — backend verifies ID tokens, no client secret.
GOOGLE_CLIENT_ID=

# ─── S3 / LocalStack ─────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=ai-job-hunter-cvs
# Custom endpoint for LocalStack. Leave blank or remove in prod for real S3.
S3_ENDPOINT=http://localhost:4566
S3_FORCE_PATH_STYLE=true

# ─── Ingestion sources ───────────────────────────────────
# Comma-separated Greenhouse "board tokens" (company slugs). The slug is the
# last segment of https://boards.greenhouse.io/<slug>. Leave empty to skip
# Greenhouse entirely.
GREENHOUSE_BOARDS=stripe,airbnb,gitlab,vercel,coinbase

# Comma-separated Lever company slugs. Slug = the path in
# https://jobs.lever.co/<slug>. Leave empty to skip.
LEVER_COMPANIES=netflix,attentive,klaviyo

# Comma-separated Ashby company slugs. Slug = the path in
# https://jobs.ashbyhq.com/<slug>. Leave empty to skip.
ASHBY_COMPANIES=linear,posthog,vanta

# How far back ingestion fetches. Even on an empty DB this cap applies, so
# we never burn API quota or OpenAI tokens on years-old job postings.
INGESTION_MAX_AGE_DAYS=7

# ─── AI service ───────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
