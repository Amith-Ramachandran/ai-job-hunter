# Root .env.example — describes shared envs across compose services.
# Each app also has its own .env.example for app-specific vars.
# Copy this file to .env and fill in values for local development.

# ─── Postgres ─────────────────────────────────────────────
POSTGRES_USER=ajh
POSTGRES_PASSWORD=ajh_dev_password
POSTGRES_DB=ai_job_hunter

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=ajh_redis_dev

# ─── LocalStack (S3) ──────────────────────────────────────
# These match the dummy creds LocalStack expects in dev.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_BUCKET=ai-job-hunter-cvs

# ─── Qdrant ───────────────────────────────────────────────
# No auth in local dev; in prod we'll set QDRANT_API_KEY.
QDRANT_URL=http://localhost:6333
